# ═══════════════════════════════════════════════════════════════════
#  PharmaTech Bot — Environment Variables (EXAMPLE)
#  Sao chép file này thành .env và điền giá trị thật của bạn vào.
#  KHÔNG BAO GIỜ commit file .env lên GitHub!
# ═══════════════════════════════════════════════════════════════════

# ── Required ─────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
GEMINI_API_KEY=your_gemini_api_key_here

# ── Admin ────────────────────────────────────────────────────────
# Chat ID Telegram của Admin để nhận bài nháp PharmaTech Daily và dùng /testnotify
# Lấy chat ID của bạn bằng cách chat với @userinfobot trên Telegram
ADMIN_TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── PharmaTech Daily ─────────────────────────────────────────────
# Bật/tắt tính năng tạo bài phân tích khoa học dược tự động hàng ngày
ENABLE_PHARMA_DAILY=false
# Giờ gửi bài nháp cho Admin duyệt (HH:MM theo timezone)
PHARMA_DAILY_TIME=07:30

# ── DAV Scraper ──────────────────────────────────────────────────
DAV_LISTINGS_URL=https://dav.gov.vn/thong-tin-xu-ly-vi-pham-cn5.html
DAV_REGISTRATION_URL=https://dav.gov.vn/dang-ki-thuoc-cn6.html
DAV_BASE_URL=https://dav.gov.vn
MAX_PDF_SIZE_MB=10

# ── International Sources ────────────────────────────────────────
ENABLE_INTERNATIONAL_SOURCES=true

# ── DAV Source Toggle ────────────────────────────────────────────
# Set to False in production environments (like Render) if the host's IP is blocked
# by the Vietnamese government firewall (dav.gov.vn), then run the local scraper instead.
ENABLE_DAV_SCRAPING=true

# ── Gemini Model ─────────────────────────────────────────────────
GEMINI_MODEL=gemini-flash-lite-latest

# ── Database ─────────────────────────────────────────────────────
# Local (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db
# Cloud (Supabase/Neon PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ── Scheduler ────────────────────────────────────────────────────
CHECK_INTERVAL_MINUTES=30
NOTIFICATION_TIMES=12:00,18:00
TIMEZONE=Asia/Ho_Chi_Minh

# ── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
